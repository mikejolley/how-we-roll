VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
# Optional: GitHub Actions sets this from the repo name. For local builds that mimic Pages, e.g.:
# VITE_PUBLIC_BASE_PATH=how-we-roll
# Or force the exact return URL Supabase must allow-list:
# VITE_OAUTH_REDIRECT_URL=https://you.github.io/your-repo/
